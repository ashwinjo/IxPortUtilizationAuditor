                "title": "Session Id"
              }
            },
            {
              "name": "confirm",
              "in": "query",
              "required": false,
              "schema": {
                "type": "boolean",
                "description": "Must be true to confirm deletion",
                "default": false,
                "title": "Confirm"
              },
              "description": "Must be true to confirm deletion"
            }
          ],
          "responses": {
            "200": {
              "description": "Successful Response",
              "content": {
                "application/json": {

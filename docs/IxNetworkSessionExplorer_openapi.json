{
    "openapi": "3.1.0",
    "info": {
      "title": "IxNetwork Session Explorer",
      "description": "Unified session manager for IxNetwork lab environments.",
      "version": "0.1.0"
    },
    "paths": {
      "/sessions/": {
        "get": {
          "tags": [
            "sessions"
          ],
          "summary": "List all sessions",
          "description": "Return all sessions grouped by server.\n\nEach server row includes IxNetwork Web probe fields (filled after a poll cycle):\n\n- ``ixnetwork_web_deployment``: ``standalone`` | ``onChassis`` | null\n- ``ixnetwork_web_heartbeat``: ``green`` | ``yellow`` | ``red``\n- ``ixnetwork_web_auth_path``, ``ixnetwork_web_detail``, ``ixnetwork_web_checked_at``\n\nResponse shape::\n\n    {\n        \"servers\": [\n            {\n                \"name\": \"ixnet-server-01\",\n                \"host\": \"10.0.0.1\",\n                \"sessions\": [...],\n                \"session_count\": 3,\n                \"ixnetwork_web_deployment\": \"standalone\",\n                \"ixnetwork_web_heartbeat\": \"green\",\n                ...\n            }\n        ]\n    }\n\nOptional query params:\n- ``?server=X`` — only include sessions from that server\n- ``?tag=bgp``  — only include sessions carrying that tag",
          "operationId": "list_sessions_sessions__get",
          "parameters": [
            {
              "name": "server",
              "in": "query",
              "required": false,
              "schema": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Filter by IxNetwork server name",
                "title": "Server"
              },
              "description": "Filter by IxNetwork server name"
            },
            {
              "name": "tag",
              "in": "query",
              "required": false,
              "schema": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Filter by tag",
                "title": "Tag"
              },
              "description": "Filter by tag"
            }
          ],
          "responses": {
            "200": {
              "description": "Successful Response",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "additionalProperties": true,
                    "title": "Response List Sessions Sessions  Get"
                  }
                }
              }
            },
            "422": {
              "description": "Validation Error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/HTTPValidationError"
                  }
                }
              }
            }
          }
        }
      },
      "/sessions/ports/{chassis}/{card}/{port}/utilized": {
        "get": {
          "tags": [
            "sessions"
          ],
          "summary": "Check if a port is in use (CP or DP active)",
          "description": "Return utilized status for a physical port identified by chassis/card/port.\n\nScans all sessions for a matching SessionPort. Returns utilized=False if the\nport is not assigned to any session (unassigned = not in use).\n\nAlways returns 200 — an unassigned port is a valid query, not an error.",
          "operationId": "get_port_utilized_sessions_ports__chassis___card___port__utilized_get",
          "parameters": [
            {
              "name": "chassis",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string",
                "title": "Chassis"
              }
            },
            {
              "name": "card",
              "in": "path",
              "required": true,
              "schema": {
                "type": "integer",
                "title": "Card"
              }
            },
            {
              "name": "port",
              "in": "path",
              "required": true,
              "schema": {
                "type": "integer",
                "title": "Port"
              }
            }
          ],
          "responses": {
            "200": {

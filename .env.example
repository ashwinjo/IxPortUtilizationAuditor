# Inventory + Session Explorer
INVENTORY_EXPLORER_URL=http://ixnse.ashai.online:3001
SESSION_EXPLORER_URL=http://ixnse.ashai.online:8080

# On-demand refresh (poll_port_metrics.py triggers before each cycle by default)
REFRESH_SETTLE_SECONDS=3
INVENTORY_POLL_TIMEOUT=120
SESSION_POLL_TIMEOUT=120

# InfluxDB 2.x (used by poll_port_metrics.py and Grafana)
INFLUXDB_URL=http://localhost:8086
# Must match DOCKER_INFLUXDB_INIT_ADMIN_TOKEN in docker-compose.yml
INFLUXDB_TOKEN=dev-influx-token-replace-in-prod
INFLUXDB_ORG=ixport
INFLUXDB_BUCKET=port_metrics
